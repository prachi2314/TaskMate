<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_dark_card.xml
    Dark rounded rectangle — general card background for dark theme
    Used in: fragment_focus.xml (card_subject_chip inner background)
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="14dp" />
    <solid android:color="@color/dark_bg_card" />
    <stroke
        android:width="1dp"
        android:color="@color/dark_stroke" />
</shape>