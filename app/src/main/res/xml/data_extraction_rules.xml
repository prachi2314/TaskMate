<?xml version="1.0" encoding="utf-8"?>
<!--
    data_extraction_rules.xml
    Location: res/xml/data_extraction_rules.xml

    Android 12+ replacement for backup_rules.xml.
    Controls data backup and device transfer behavior.
-->
<data-extraction-rules>

    <cloud-backup>
        <!-- Exclude sensitive local data from cloud backup -->
        <exclude
            domain="sharedpref"
            path="." />
        <exclude
            domain="database"
            path="." />
        <exclude
            domain="cache"
            path="." />
    </cloud-backup>

    <device-transfer>
        <!-- Allow user preferences to transfer to new device -->
        <include
            domain="sharedpref"
            path="taskmate_prefs.xml" />
        <!-- Exclude credentials and tokens -->
        <exclude
            domain="sharedpref"
            path="com.google.android.gms.measurement.prefs.xml" />
    </device-transfer>

</data-extraction-rules>