<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/dashboardFragment">

    <!-- Dashboard -->
    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.taskmate.ui.dashboard.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard" />

    <!-- Timetable -->
    <fragment
        android:id="@+id/timetableFragment"
        android:name="com.example.taskmate.ui.timetable.TimetableFragment"
        android:label="Timetable"
        tools:layout="@layout/fragment_timetable" />

    <!-- Subject list -->
    <fragment
        android:id="@+id/subjectFragment"
        android:name="com.example.taskmate.ui.subject.SubjectFragment"
        android:label="Subjects"
        tools:layout="@layout/fragment_subject">

        <!-- Navigate to subject detail -->
        <action
            android:id="@+id/action_subject_to_detail"
            app:destination="@id/subjectDetailFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />

    </fragment>

    <!-- Subject detail — shows chapter list -->
    <fragment
        android:id="@+id/subjectDetailFragment"
        android:name="com.example.taskmate.ui.subject.SubjectDetailFragment"
        android:label="Subject Detail"
        tools:layout="@layout/fragment_subject_detail">

        <!-- Argument to pass subject ID -->
        <argument
            android:name="subjectId"
            app:argType="string"
            android:defaultValue="" />

    </fragment>

    <!-- Progress -->
    <fragment
        android:id="@+id/progressFragment"
        android:name="com.example.taskmate.ui.progress.ProgressFragment"
        android:label="Progress"
        tools:layout="@layout/fragment_progress" />

    <!-- Focus -->
    <fragment
        android:id="@+id/focusFragment"
        android:name="com.example.taskmate.ui.focus.FocusFragment"
        android:label="Focus"
        tools:layout="@layout/fragment_focus" />

</navigation>