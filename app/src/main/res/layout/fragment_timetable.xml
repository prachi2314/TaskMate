<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_timetable.xml
    Location: res/layout/fragment_timetable.xml
    Host: DashboardActivity → Navigation Component
    Sections:
      1. Header band (title + week label)
      2. Day chip horizontal scroll strip
      3. Schedule RecyclerView
      4. Empty state TextView
      5. FAB — add slot
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_timetable"
    tools:context=".ui.timetable.TimetableFragment">

    <!-- ══════════════════════════════════════════════════════════
         HEADER BAND — title + week range label
    ══════════════════════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header_timetable"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/blue_50"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Screen title -->
        <TextView
            android:id="@+id/tv_timetable_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Timetable"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/blue_900"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:ignore="HardcodedText" />

        <!-- Week range label — e.g. "Week of Apr 7 – 13, 2026" -->
        <TextView
            android:id="@+id/tv_timetable_week"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textSize="12sp"
            android:textColor="@color/blue_400"
            app:layout_constraintTop_toBottomOf="@id/tv_timetable_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Week of Apr 7 – 13, 2026" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ══════════════════════════════════════════════════════════
         DAY CHIP STRIP
         HorizontalScrollView allows more days without overflow.
         Day chips are created programmatically in TimetableFragment.
         The LinearLayout ll_day_chips is the container.
    ══════════════════════════════════════════════════════════ -->
    <HorizontalScrollView
        android:id="@+id/scroll_days"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="@color/blue_50"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        app:layout_constraintTop_toBottomOf="@id/header_timetable"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Day chip buttons are added programmatically
             in TimetableFragment.setupDayChips() -->
        <LinearLayout
            android:id="@+id/ll_day_chips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical" />

    </HorizontalScrollView>

    <!-- ══════════════════════════════════════════════════════════
         DIVIDER LINE — separates day chips from schedule list
    ══════════════════════════════════════════════════════════ -->
    <View
        android:id="@+id/divider_timetable"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/blue_100"
        app:layout_constraintTop_toBottomOf="@id/scroll_days"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════════════════════════════════════════════
         SCHEDULE RECYCLERVIEW
         Shows time-slotted subject cards for the selected day.
         Each row uses item_schedule_slot.xml via ScheduleAdapter.
         nestedScrollingEnabled = false not needed here since
         this is the only scrollable element on screen.
    ══════════════════════════════════════════════════════════ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_schedule"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="12dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/divider_timetable"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_schedule_slot"
        tools:itemCount="5" />

    <!-- ══════════════════════════════════════════════════════════
         EMPTY STATE
         Shown when no schedule slots exist for the selected day.
         Visibility is toggled in TimetableFragment.observeViewModel()
    ══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/tv_no_slots"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/divider_timetable"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/fab_add_slot"
        tools:visibility="visible">

        <!-- Empty state icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅"
            android:textSize="48sp"
            android:layout_marginBottom="12dp"
            tools:ignore="HardcodedText" />

        <!-- Empty state title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No classes today"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/blue_600"
            android:gravity="center"
            tools:ignore="HardcodedText" />

        <!-- Empty state subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Tap the + button to add a schedule slot"
            android:textSize="13sp"
            android:textColor="@color/blue_300"
            android:gravity="center"
            tools:ignore="HardcodedText" />

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════
         FAB — Add new schedule slot
         Tapping opens AddSlotBottomSheet.
         Positioned bottom-end with 16dp margin.
    ══════════════════════════════════════════════════════════ -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_slot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:contentDescription="Add schedule slot"
        android:src="@drawable/ic_add_24"
        app:backgroundTint="@color/blue_600"
        app:tint="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>