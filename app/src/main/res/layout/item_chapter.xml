<?xml version="1.0" encoding="utf-8"?>
<!--
    item_chapter.xml
    Shows one chapter with:
    - Chapter number + name
    - Completed checkbox
    - Revised badge
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/purple_100"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Chapter number badge -->
        <TextView
            android:id="@+id/tv_chapter_number"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/bg_session_dot_active"
            android:layout_marginEnd="10dp"
            tools:text="1" />

        <!-- Chapter name -->
        <TextView
            android:id="@+id/tv_chapter_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="13sp"
            android:textColor="@color/purple_900"
            tools:text="Introduction to Data Structures" />

        <!-- Revised badge -->
        <TextView
            android:id="@+id/tv_revised_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="Revised ✓"
            android:textSize="9sp"
            android:textColor="@color/teal_700"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:background="@drawable/bg_badge_ok"
            android:visibility="gone"
            tools:visibility="visible"
            tools:ignore="HardcodedText" />

        <!-- Completed checkbox -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cb_chapter_done"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="@color/purple_600" />

    </LinearLayout>
</androidx.cardview.widget.CardView>