<?xml version="1.0" encoding="utf-8"?>
<!--
    bottom_sheet_add_task.xml
    Location: res/layout/bottom_sheet_add_task.xml
    Used in: AddTaskBottomSheet
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white"
    android:paddingBottom="32dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_streak_empty"
        android:backgroundTint="@color/gray_300" />

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Add new task"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/purple_900"
            tools:ignore="HardcodedText" />

        <ImageButton
            android:id="@+id/btn_close_task_sheet"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close_24"
            android:contentDescription="Close" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/purple_100" />

    <!-- Form content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Task title input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_task_title"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:hint="What do you need to do?"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/input_stroke_default"
                app:hintTextColor="@color/purple_400"
                app:startIconDrawable="@drawable/ic_check_24"
                app:startIconTint="@color/purple_400"
                tools:ignore="HardcodedText">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_task_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences"
                    android:textSize="14sp"
                    android:textColor="@color/purple_900"
                    android:imeOptions="actionNext" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Task description (optional) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_task_description"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:hint="Description (optional)"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/input_stroke_default"
                app:hintTextColor="@color/purple_400"
                tools:ignore="HardcodedText">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_task_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine|textCapSentences"
                    android:minLines="2"
                    android:textSize="14sp"
                    android:textColor="@color/purple_900" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Subject dropdown -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_task_subject"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:hint="Subject (optional)"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/input_stroke_default"
                app:hintTextColor="@color/purple_400"
                app:startIconDrawable="@drawable/ic_book_24"
                app:startIconTint="@color/purple_400"
                tools:ignore="HardcodedText">

                <AutoCompleteTextView
                    android:id="@+id/acv_task_subject"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:textSize="14sp"
                    android:textColor="@color/purple_900"
                    tools:text="Mathematics" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Due date picker button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pick_due_date"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="16dp"
                android:text="Set due date (optional)"
                app:icon="@drawable/ic_schedule_24"
                app:iconGravity="start"
                app:iconSize="18dp"
                app:strokeColor="@color/purple_200"
                app:cornerRadius="12dp"
                android:textColor="@color/purple_600"
                tools:ignore="HardcodedText" />

            <!-- Priority selector label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Priority"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/purple_600"
                android:layout_marginBottom="8dp"
                tools:ignore="HardcodedText" />

            <!-- Priority chip group -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_priority"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:singleSelection="true"
                app:chipSpacingHorizontal="8dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_priority_low"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Low"
                    android:textSize="12sp"
                    android:checked="true"
                    app:chipBackgroundColor="@color/teal_50"
                    app:checkedIconTint="@color/teal_600"
                    tools:ignore="HardcodedText" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_priority_medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Medium"
                    android:textSize="12sp"
                    app:chipBackgroundColor="@color/amber_50"
                    app:checkedIconTint="@color/amber_600"
                    tools:ignore="HardcodedText" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_priority_high"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="High"
                    android:textSize="12sp"
                    app:chipBackgroundColor="@color/red_50"
                    app:checkedIconTint="@color/red_600"
                    tools:ignore="HardcodedText" />

            </com.google.android.material.chip.ChipGroup>

            <!-- Save button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_task"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Add task"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="@color/purple_600"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_add_24"
                app:iconGravity="start"
                app:iconSize="18dp"
                tools:ignore="HardcodedText" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>