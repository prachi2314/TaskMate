<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_dashboard.xml
    Location: res/layout/fragment_dashboard.xml
    Host: DashboardActivity → Navigation Component
    Sections:
      Header band  (greeting + avatar + stats)
      Scrollable content:
        ├── Today's tasks card
        ├── Subject progress card
        └── Upcoming exams card
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/background_page"
    tools:context=".ui.dashboard.DashboardFragment">

    <!-- ══════════════════════════════════════════
         HEADER — purple band with greeting + stats
    ══════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/purple_600"
        app:elevation="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- Greeting -->
            <TextView
                android:id="@+id/tv_greeting"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Good morning,"
                android:textSize="12sp"
                android:textColor="@color/purple_200"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/iv_avatar"
                tools:ignore="HardcodedText" />

            <!-- Student name -->
            <TextView
                android:id="@+id/tv_student_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                app:layout_constraintTop_toBottomOf="@id/tv_greeting"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/iv_avatar"
                tools:text="Arjun Mehta" />

            <!-- Avatar -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_avatar"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@color/pink_100"
                android:padding="2dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Circle"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toTopOf="@id/stats_barrier"
                tools:src="@tools:sample/avatars" />

            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/stats_barrier"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="tv_student_name,iv_avatar" />

            <!-- Stat: Today -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_stat_today"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="#26FFFFFF"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toBottomOf="@id/stats_barrier"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/card_stat_streak">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingVertical="8dp">
                    <TextView
                        android:id="@+id/tv_today_hours"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        tools:text="4h 20m" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Today"
                        android:textSize="10sp"
                        android:textColor="@color/purple_200"
                        tools:ignore="HardcodedText" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Stat: Streak -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_stat_streak"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="#26FFFFFF"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toBottomOf="@id/stats_barrier"
                app:layout_constraintStart_toEndOf="@id/card_stat_today"
                app:layout_constraintEnd_toStartOf="@id/card_stat_overall">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingVertical="8dp">
                    <TextView
                        android:id="@+id/tv_streak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        tools:text="7" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Streak"
                        android:textSize="10sp"
                        android:textColor="@color/purple_200"
                        tools:ignore="HardcodedText" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Stat: Overall -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_stat_overall"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#26FFFFFF"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toBottomOf="@id/stats_barrier"
                app:layout_constraintStart_toEndOf="@id/card_stat_streak"
                app:layout_constraintEnd_toEndOf="parent">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingVertical="8dp">
                    <TextView
                        android:id="@+id/tv_overall_percent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        tools:text="68%" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Overall"
                        android:textSize="10sp"
                        android:textColor="@color/purple_200"
                        tools:ignore="HardcodedText" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ══════════════════════════════════════════
         SCROLLABLE CONTENT
    ══════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Tasks card ──────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_tasks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:id="@+id/tv_tasks_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Today's tasks"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/purple_600"
                            tools:ignore="HardcodedText" />

                        <TextView
                            android:id="@+id/tv_tasks_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="@color/purple_400"
                            tools:text="2/4 done" />
                    </LinearLayout>

                    <!-- Loading shimmer shown while tasks load -->
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progress_tasks_loading"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone"
                        android:indeterminate="true"
                        app:indicatorColor="@color/purple_500"
                        app:trackColor="@color/purple_100"
                        app:trackCornerRadius="4dp"
                        tools:visibility="visible" />

                    <!-- Empty state -->
                    <TextView
                        android:id="@+id/tv_no_tasks"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="16dp"
                        android:text="No tasks for today. Add one below!"
                        android:textSize="13sp"
                        android:textColor="@color/purple_300"
                        android:visibility="gone"
                        tools:visibility="visible"
                        tools:ignore="HardcodedText" />

                    <!-- Task list -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_tasks"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_task"
                        tools:itemCount="4" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Subject progress card ───────────────────────── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_subjects"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tv_subjects_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Subject progress"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/purple_600"
                        android:layout_marginBottom="10dp"
                        tools:ignore="HardcodedText" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_subjects"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_subject"
                        tools:itemCount="4" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Upcoming exams card ─────────────────────────── -->
            <!-- ── Upcoming Exams Card ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_exams"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- Header row with title + add button -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:id="@+id/tv_exams_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Upcoming exams"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/purple_600"
                            tools:ignore="HardcodedText" />

                        <!-- Add Exam Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_add_exam"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="+ Add Exam"
                            android:textSize="11sp"
                            android:paddingHorizontal="10dp"
                            android:textColor="@color/purple_600"
                            app:strokeColor="@color/purple_300"
                            app:strokeWidth="1dp"
                            app:cornerRadius="20dp"
                            tools:ignore="HardcodedText" />

                    </LinearLayout>

                    <!-- Empty state for exams -->
                    <TextView
                        android:id="@+id/tv_no_exams"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No upcoming exams. Add one!"
                        android:textSize="12sp"
                        android:textColor="@color/purple_300"
                        android:gravity="center"
                        android:padding="8dp"
                        android:visibility="gone"
                        tools:visibility="visible"
                        tools:ignore="HardcodedText" />

                    <!-- Exams RecyclerView -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_exams"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_exam"
                        tools:itemCount="2" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── FAB — add task ─────────────────────────────────────── -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_task"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:contentDescription="Add task"
        android:src="@drawable/ic_add_24"
        app:backgroundTint="@color/purple_600"
        app:tint="@color/white" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>